# Environment (development | production)
ENVIRONMENT=production

# Allowed CORS origin in production (your frontend domain)
CORS_ORIGIN=https://yoursite.one.com

# Database Configuration
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_username
DB_PASS=your_database_password

# JWT Secret (generate a random string)
JWT_SECRET=change-this-to-a-random-secret-key-min-32-chars

# Mail Configuration
MAIL_FROM=noreply@yoursite.one.com

# Site URL
SITE_URL=https://yoursite.one.com

# Analytics hash salt (generate a random string)
LOG_HASH_SALT=change-this-to-a-random-secret-salt

# Gemini API key (server-side only — do NOT put this in the frontend .env)
GEMINI_API_KEY=your-gemini-api-key-here
